# ─────────────────────────────────────────────────────────────────
# HomeVoice — Environment Variables
# Copy this file to .env.local and fill in your keys.
# The app works without all keys — it uses demo data for any
# missing source and skips audio if no TTS key is provided.
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────

# Anthropic (Claude) — for podcast script generation
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase — auth + database (user profiles, podcast history)
# Get at: https://supabase.com → New Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── PROPERTY DATA (at least one recommended) ──────────────────────

# Zillow via RapidAPI — primary property data source
# Get at: https://rapidapi.com/apimaker/api/zillow56 (search "Zillow56")
RAPIDAPI_KEY=your_rapidapi_key_here

# Rentcast — fallback property data (cheaper, no scraping)
# Get at: https://app.rentcast.io/app/api-access
RENTCAST_API_KEY=your_rentcast_api_key_here

# ── MARKET NEWS (at least one recommended) ────────────────────────

# Serper — Google Search API for local real estate news
# Get at: https://serper.dev  (~$1 per 1,000 queries)
SERPER_API_KEY=your_serper_api_key_here

# Tavily — alternative AI-optimized search API
# Get at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ── TEXT-TO-SPEECH (at least one recommended) ─────────────────────

# ElevenLabs — high-quality AI voice (primary TTS)
# Get at: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: override the default ElevenLabs voice
# Default is "Rachel" (voice ID: 21m00Tcm4TlvDq8ikWAM)
# Browse voices at: https://elevenlabs.io/voice-library
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# OpenAI — fallback TTS (also used if you prefer OpenAI voices)
# Get at: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here
